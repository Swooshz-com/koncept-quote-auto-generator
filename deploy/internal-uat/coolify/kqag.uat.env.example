# KQAG single-instance internal UAT placeholders for Coolify.
# Copy into Coolify secrets/environment management. Do not commit real values.

APP_MODE=deploy
AUTH_REQUIRED=true
SESSION_SECRET=<generate-on-server-or-secret-store-do-not-commit>

OIDC_ISSUER_URL=<placeholder>
OIDC_CLIENT_ID=<placeholder>
OIDC_CLIENT_SECRET=<placeholder>
OIDC_REDIRECT_URI=https://quote-uat.example.com/callback
OIDC_AUTHORIZE_URL=<placeholder>
OIDC_TOKEN_URL=<placeholder>
OIDC_USERINFO_URL=<placeholder>
OIDC_LOGOUT_URL=<optional-placeholder>

AUTH_ALLOWED_EMAILS=<placeholder>
AUTH_ALLOWED_DOMAINS=<placeholder>
AUTH_ALLOW_ANY_AUTHENTICATED_USER=false
AUTH_APPROVED_TESTER_ROLE=admin

QUOTE_DATA_ROOT=/var/lib/kqag/data
QUOTE_OUTPUT_ROOT=/var/lib/kqag/output
QUOTE_TMP_ROOT=/var/lib/kqag/tmp
QUOTE_LOG_ROOT=/var/log/kqag

PORT=8765
