# OpenAI API for local development.
OPENAI_API_KEY=
OPENAI_DRAFT_MODEL=gpt-5.5
OPENAI_DRAFT_REASONING_EFFORT=xhigh
OPENAI_BASIS_LINE_MODEL=gpt-5.4-mini
OPENAI_BASIS_ANSWER_MODEL=gpt-5.4-nano
OPENAI_REQUEST_TIMEOUT_SECONDS=1800

# Optional DeepSeek Pro for text-only AI jobs. Full PDF/image draft analysis still uses OpenAI vision.
# When set, DeepSeek is tried first for Re, quote-basis text changes, and pricing-reference import, with OpenAI fallback.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# Local app defaults. Keep these for normal desktop development.
APP_MODE=local
# Local dev role: ADMIN, USER, management, operator, or viewer.
USER_TYPE=ADMIN

# Required only for deployed authenticated mode.
AUTH_REQUIRED=false
SESSION_SECRET=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_LOGOUT_URL=
