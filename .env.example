# OpenAI API for local development.
OPENAI_API_KEY=
OPENAI_DRAFT_MODEL=gpt-5.5
OPENAI_BASIS_LINE_MODEL=gpt-5.4-mini
OPENAI_BASIS_ANSWER_MODEL=gpt-5.4-nano
OPENAI_REQUEST_TIMEOUT_SECONDS=1800

# Local runner safety defaults.
APP_MODE=local
# Simulated production permission level for local testing: ADMIN or USER.
USER_TYPE=ADMIN
# Advanced fallback role override: admin, management, operator, or viewer.
LOCAL_USER_ROLE=

# Required only for deployed authenticated mode.
AUTH_REQUIRED=false
SESSION_SECRET=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_LOGOUT_URL=
