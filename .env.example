# Optional AI providers for local development.
OPENAI_API_KEY=
OPENAI_DRAFT_MODEL=gpt-5.4-mini
OPENAI_BASIS_LINE_MODEL=gpt-5.4-nano
OPENAI_REQUEST_TIMEOUT_SECONDS=90

GEMINI_API_KEY=
GEMINI_DRAFT_MODEL=gemini-flash-latest
GEMINI_BASIS_LINE_MODEL=gemini-3.1-flash-lite
GEMINI_REQUEST_TIMEOUT_SECONDS=90

# Local runner safety defaults.
APP_MODE=local
LOCAL_USER_ROLE=admin

# Required only for deployed authenticated mode.
AUTH_REQUIRED=false
SESSION_SECRET=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_LOGOUT_URL=
