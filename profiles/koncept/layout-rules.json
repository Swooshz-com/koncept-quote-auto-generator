{
  "schema_version": 1,
  "profile_id": "koncept",
  "output": {
    "master_format": "xlsx",
    "pdf_default": "disabled",
    "currency": "SGD"
  },
  "template": {
    "workbook": "quotation-layout.xlsx",
    "worksheet": "Quotation",
    "print_area_columns": "A:I"
  },
  "header": {
    "client_block": {
      "position": "top-left",
      "alignment": "left",
      "fields": ["client.name", "client.address", "client.attention", "client.title", "quote_date", "project.title"]
    },
    "company_block": {
      "position": "top-right",
      "alignment": "left",
      "show_details_on_first_page_only": true,
      "repeat_logo_on_continuation_pages": true
    }
  },
  "line_items": {
    "columns": ["Pos.", "Quantity", "Service", "Estimate"],
    "quantity_alignment": "center",
    "estimate_alignment": "right",
    "square_metre_unit": "sqm",
    "show_internal_costs": false,
    "numeric_price_format": "#,##0.00",
    "section_rows": {
      "number_format": "0.0",
      "amount_mode": "itemized_by_default"
    },
    "detail_rows": {
      "number_format": "0.0",
      "allowed_display_prices": ["numeric", "FOC", "Included"]
    }
  },
  "totals": {
    "labels": ["Total", "GST 9%", "Total including GST"],
    "keep_rows_together": true,
    "border_scope": ["label", "amount", "currency"]
  },
  "terms_notes_signature": {
    "payment_terms_bold": true,
    "notes_numbering": "plain_sequential",
    "acceptance_block_separate_from_notes": true,
    "signature_blocks": ["company", "customer"]
  },
  "security": {
    "treat_text_as_untrusted_spreadsheet_text": true,
    "escape_formula_prefixes": ["=", "+", "-", "@"],
    "frontend_exposes_internal_pricing": false
  }
}
